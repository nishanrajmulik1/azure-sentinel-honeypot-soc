SecurityEvent
| where EventID == 4625
| where IpAddress != "-" and isnotempty(IpAddress)
| summarize UniqueAccountsTargeted = dcount(Account),
            TotalAttempts = count(),
            SampleAccounts = make_set(Account, 20)
            by IpAddress, bin(TimeGenerated, 30m)
| where UniqueAccountsTargeted > 10
| extend GeoInfo = geo_info_from_ip_address(IpAddress)
| extend AttackerCountry = tostring(GeoInfo.country)
